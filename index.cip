  <!-- STYLE -->
  <style>

    html{
      scroll-behavior:smooth;
    }

    body{
      background:#000;
      overflow-x:hidden;
      color:#f5e7a1;
      font-family:'Cormorant Garamond', serif;
    }

    h1,h2,h3,h4,.luxury-font{
      font-family:'Cinzel', serif;
    }

    /* GOLD TEXT */

    .gold-text{

      background:linear-gradient(
        to bottom,
        #fff8d6,
        #f7d774,
        #d4af37,
        #8f6b10
      );

      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;

      text-shadow:
        0 0 10px rgba(255,215,0,0.15),
        0 0 25px rgba(255,215,0,0.08);

    }

    /* GLASS */

    .glass{
      background:rgba(10,10,10,0.45);
      backdrop-filter:blur(18px);
    }

    /* GOLD GLOW */

    .gold-glow{

      box-shadow:
        0 0 20px rgba(255,215,0,0.15),
        0 0 60px rgba(255,215,0,0.08),
        0 0 120px rgba(255,215,0,0.04);

    }

    /* FLOAT */

    .floating{
      animation:float 20s ease-in-out infinite;
    }

    @keyframes float{

      0%{
        transform:translateY(0px);
      }

      50%{
        transform:translateY(-12px);
      }

      100%{
        transform:translateY(0px);
      }

    }

    /* GOLD PULSE */

    .pulse-gold{
      animation:pulseGold 4s ease-in-out infinite;
    }

    @keyframes pulseGold{

      0%,100%{

        box-shadow:
          0 0 20px rgba(255,215,0,0.15),
          0 0 60px rgba(255,215,0,0.08);

      }

      50%{

        box-shadow:
          0 0 40px rgba(255,215,0,0.3),
          0 0 120px rgba(255,215,0,0.18);

      }

    }

    /* SPIN */

    .spin-slow{
      animation:spin 35s linear infinite;
    }

    @keyframes spin{

      from{
        transform:rotate(0deg);
      }

      to{
        transform:rotate(360deg);
      }

    }

    /* HERO SHADOW */

    .hero-shadow{

      text-shadow:
        0 0 10px rgba(255,215,0,.18),
        0 0 30px rgba(255,215,0,.12),
        0 0 40px rgba(255,215,0,.08);

    }

    /* CARD */

    .luxury-card{

      background:rgba(15,15,15,0.55);

      border:1px solid rgba(255,215,0,0.12);

      backdrop-filter:blur(10px);

      box-shadow:
        0 0 20px rgba(255,215,0,0.05);

      transition:all .4s ease;

    }

    .luxury-card:hover{

      transform:translateY(-10px);

      border-color:rgba(255,215,0,0.35);

      box-shadow:
        0 0 20px rgba(255,215,0,0.12);

    }

    /* BUTTON */

    .gold-button{

      background:linear-gradient(
        to right,
        #fff0a6,
        #d4af37,
        #8f6b10
      );

    }

    /* MEDIA BUTTONS */

    .media-btn{

      padding:16px 28px;

      border-radius:18px;

      font-weight:400;

      letter-spacing:1px;

      color:white;

      text-decoration:none;

      transition:0.35s;

      backdrop-filter:blur(12px);

      border:1px solid rgba(255,255,255,0.15);

      box-shadow:
        0 0 20px rgba(255,255,255,0.08);

      text-transform:uppercase;

      font-size:14px;

      min-width:100px;

    }

    /* MALAYSIA */

    .malaysia-btn{

      background:
      linear-gradient(
        to right,
        #001a66,
        #c00000,
        #ffd700
      );

    }

    /* GLOBAL */

    .global-btn{

      background:
      linear-gradient(
        to right,
        #00c6ff,
        #0072ff
      );

    }

    /* ENTERTAINMENT */

    .entertainment-btn{

      background:
      linear-gradient(
        to right,
        #ff00cc,
        #3333ff
      );

    }

    /* SPORTS */

    .sports-btn{

      background:
      linear-gradient(
        to right,
        #00c853,
        #b2ff59
      );

      color:black;

    }

    /* HOVER */

    .media-btn:hover{

      transform:
        translateY(-5px)
        scale(1.05);

      box-shadow:
        0 0 35px rgba(255,255,255,0.25);

    }

  /* GLOBE */

.nanis-globe{

  width:120px;
  height:120px;

  border-radius:50%;

  border:2px solid rgba(255,215,0,0.25);

  background:

  radial-gradient(
    circle at center,
    rgba(255,215,0,0.15),
    rgba(0,0,0,0.2)
  );

  box-shadow:
    0 0 50px rgba(255,215,0,0.25),
    0 0 150px rgba(255,215,0,0.12);

  animation:
    globeSpin 40s linear infinite;

}

@keyframes globeSpin{

  from{
    transform:rotate(0deg);
  }

  to{
    transform:rotate(360deg);
  }

}

/* BUSINESS CARD EFFECT */

.luxury-card{
  transition: all 0.4s ease;
}

.luxury-card:hover{
  transform: translateY(-8px);
  box-shadow: 0 15px 40px rgba(255,215,0,0.15);
}
</style>

<!-- LIVE MALAYSIA NEWS BAR -->

<div class="malaysia-news-wrapper">

  <!-- LEFT LIVE -->
  <div class="live-malaysia">

    <span class="live-dot"></span>

    🇲🇾 LIVE NEWS

  </div>

  <!-- NEWS -->
  <div id="rss-news" class="malaysia-news-container">

    Loading berita rasmi Malaysia...

  </div>

</div>

<!-- RSS STYLE -->

<style>

/* RSS CARD */

.rss-item{

  padding:16px;

  border-radius:18px;

  background:rgba(255,255,255,0.03);

  border:1px solid rgba(255,215,0,0.08);

  transition:0.3s;

}

.rss-item:hover{

  transform:translateY(-5px);

  border-color:rgba(255,215,0,0.35);

  box-shadow:
    0 0 25px rgba(255,215,0,0.12);

}

.rss-item a{

  color:#fff;

  text-decoration:none;

  font-weight:yy00;

  line-height:1.6;

}

.rss-item a:hover{

  color:#ffd700;

}

/* MAIN BAR */

.malaysia-news-wrapper{

  width:80%;

  height:60px;

  display:flex;

  align-items:center;

  overflow:hidden;

  position:justify;

  top:0;

  left:0;

  z-index:50;

  border-top:2px solid #ffd700;

  border-bottom:2px solid #ffd700;

  background:
  linear-gradient(
    100deg,
    #001a66 0%,
    #001a66 20%,
    #cc0000 20%,
    #cc0000 40%,
    #ffffff 40%,
    #ffffff 60%,
    #ffd700 60%,
    #ffd700 80%
  );

  box-shadow:
    0 0 30px rgba(255,215,0,0.4),
    0 0 80px rgba(255,0,0,0.2);

}

/* LIVE SIDE */

.live-malaysia{

  display:flex;

  align-items:center;

  gap:12px;

  padding:20px 32px;

  background:rgba(0,0,0,0.65);

  backdrop-filter:blur(15px);

  color:#ffffff;

  font-weight:800;

  font-size:24px;

  letter-spacing:2px;

  white-space:nowrap;

  border-right:2px solid rgba(255,255,255,0.2);

  text-shadow:
    0 0 15px rgba(255,255,255,0.4);

}

/* LIVE DOT */

.live-dot{

  width:14px;

  height:14px;

  border-radius:50%;

  background:#ff0000;

  box-shadow:
    0 0 20px #ff0000;

  animation:livePulse 1.2s infinite;

}

@keyframes livePulse{

  0%{
    transform:scale(1);
    opacity:1;
  }

  50%{
    transform:scale(1.6);
    opacity:.5;
  }

  100%{
    transform:scale(1);
    opacity:1;
  }

}

/* NEWS AREA */

.malaysia-news-container{

  flex:1;

  overflow:hidden;

  white-space:nowrap;

  color:#ffffff;

  font-size:20px;

  font-weight:500;

  letter-spacing:1px;

  text-shadow:
    0 0 10px rgba(0,0,0,0.7);

}

/* SCROLL */

.news-scroll{

  display:inline-block;

  padding-left:100%;

  animation:malaysiaScroll 70s linear infinite;

}

/* NEWS LINK */

.news-scroll a{

  color:#ffffff;

  text-decoration:none;

  margin-right:90px;

  transition:0.3s;

}

.news-scroll a:hover{

  color:#ffd700;

  text-shadow:
    0 0 15px rgba(255,215,0,0.7);

}

/* ANIMATION */

@keyframes malaysiaScroll{

  0%{
    transform:translateX(0%);
  }

  100%{
    transform:translateX(-100%);
  }

}

/* MOBILE */

@media(max-width:700px){

  .live-malaysia{

    padding:16px 20px;

    font-size:14px;

    letter-spacing:1px;

  }

  .malaysia-news-container{

    font-size:14px;

  }

}

</style>

<!-- RSS SCRIPT -->

<script>

fetch(
  "https://api.rss2json.com/v1/api.json?rss_url=https://berita.rtm.gov.my/rss"
)

.then(response => response.json())

.then(data => {

  let output = '<div class="news-scroll">';

  data.items.slice(0,10).forEach(item => {

    output += `

      <a href="${item.link}" target="_blank">

        🇲🇾 ${item.title}

      </a>

    `;

  });

  output += '</div>';

  document.getElementById("rss-news").innerHTML = output;

})

.catch(error => {

  document.getElementById("rss-news").innerHTML =
  "Berita rasmi Malaysia sedang dikemaskini...";

});

</script>
  
